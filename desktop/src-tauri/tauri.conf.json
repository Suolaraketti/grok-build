{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grok Build",
  "version": "1.0.1",
  "identifier": "ai.x.grok-build.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Grok Build",
        "width": 1240,
        "height": 860,
        "minWidth": 760,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; ipc-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Grok Build — AI coding agent",
    "longDescription": "Desktop chat interface for Grok Build, SpaceXAI's AI coding agent. Talks to the grok agent runtime over the Agent Client Protocol.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/": "resources/"
    }
  }
}
